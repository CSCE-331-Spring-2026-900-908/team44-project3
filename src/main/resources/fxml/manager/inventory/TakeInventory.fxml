<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the take inventory screen in the manager inventory section, defining the user interface components and their arrangement.
This layout includes a back button, a label for the screen title, a TableView for displaying the current inventory with columns for 
item name, category, current quantity, unit, and reorder threshold, buttons for adding and deleting inventory items, and a section for 
updating inventory quantities with a ComboBox for selecting an item, a TextField for entering the new quantity, and an update button.
The components are arranged in a VBox with appropriate spacing to create a clear and organized interface for the manager to view and manage inventory levels.-->
<StackPane 
   fx:controller="team44.project2.controller.manager.inventory.TakeInventoryController"
   xmlns="http://javafx.com/javafx/25"
   xmlns:fx="http://javafx.com/fxml/1"
   prefHeight="600.0"
   prefWidth="800.0">

   <children>
      <VBox spacing="10">
         <children>
            <HBox spacing="10">
               <children>
                  <Button text="Back" onAction="#handleBack"/>
               </children>
            </HBox>
            
            <Label text="Current Inventory" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            
            <TableView fx:id="inventoryTable" prefHeight="300" prefWidth="800">
               <columns>
                  <TableColumn fx:id="itemNameColumn" text="Item Name" prefWidth="200"/>
                  <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                  <TableColumn fx:id="currentQuantityColumn" text="Current Quantity" prefWidth="150"/>
                  <TableColumn fx:id="unitColumn" text="Unit" prefWidth="100"/>
                  <TableColumn fx:id="reorderThresholdColumn" text="Reorder Threshold" prefWidth="150"/>
               </columns>
            </TableView>
            
               <HBox spacing="10">
                  <children>
                     <Button text="Add Item" onAction="#handleAddInventory" />
                     <Button text="Delete Item" onAction="#handleDeleteInventory" />
                  </children>
               </HBox>
            
            <Label text="Update Inventory" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            
            <VBox spacing="10">
               <children>
                  <HBox spacing="10">
                     <children>
                        <ComboBox fx:id="itembox" prefWidth="200.0" promptText="Select Item" />
                        <TextField fx:id="quantityField" promptText="New Quantity"/>
                        <Button text="Update" onAction="#handleAddItem"/>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>