<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the main ordering screen in the cashier ordering process, defining the user interface components and their arrangement.
This layout includes a FlowPane for displaying menu categories on the left, and a right pane that shows the current customer's name, 
a ListView for the current ticket items, a label for the total price, and buttons for customer check-in and charging. 
The top of the layout includes a log out button for the cashier to end their session.-->
<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="team44.project2.controller.cashier.ordering.OrderingScreenController">
    <center>
        <FlowPane fx:id="categoryPane" hgap="10.0" vgap="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </FlowPane>
    </center>
    <right>
        <VBox prefWidth="250.0" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="customerLabel" text="No Customer"/>
                <ListView fx:id="ticketListView" VBox.vgrow="ALWAYS"/>
                <Label fx:id="totalLabel" text="Total: $0.00"/>
                <Button fx:id="customerCheckInButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        onAction="#handleCustomerCheckIn" text="Customer Check In"/>
                <Button fx:id="chargeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        onAction="#handleCharge" text="Charge $0.00"/>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </VBox>
    </right>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="logOutButton" mnemonicParsing="false" onAction="#handleLogOut" text="Log Out" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </HBox>
    </top>
</BorderPane>