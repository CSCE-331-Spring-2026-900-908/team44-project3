<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the inventory refill order screen in the manager inventory section, defining the user interface components and their arrangement.
This layout includes a label for the screen title, a TableView for displaying low stock inventory items with columns for 
item name, category, quantity, and unit, and a section for entering the reorder quantity and submitting the refill order.
The components are arranged in a VBox with appropriate spacing to create a clear and organized interface for 
the manager to view low stock items and place refill orders.-->
<StackPane
    fx:controller="team44.project2.controller.manager.inventory.InventoryRefillOrderController"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    prefHeight="500.0"
    prefWidth="700.0">

    <children>
        <VBox spacing="10" prefWidth="700.0" prefHeight="500.0">
            <children>
                <Label text="Low Stock Inventory - Refill Orders" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <TableView fx:id="lowStockTable" prefHeight="350.0" prefWidth="700.0">
                    <columns>
                        <TableColumn fx:id="itemColumn" text="Item" prefWidth="200"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                        <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="150"/>
                        <TableColumn fx:id="unitColumn" text="Unit" prefWidth="150"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <children>
                        <Label text="Reorder Quantity:" />
                        <TextField fx:id="reorderQuantityField" prefWidth="100.0"/>
                        <Button fx:id="submitOrderButton" text="Submit Order" onAction="#handleSubmitOrder"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>