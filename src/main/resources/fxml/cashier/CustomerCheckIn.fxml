<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the customer check-in screen in the cashier process, defining the user interface components and their arrangement.
This layout includes a title label, a text field for entering the customer's phone number, a status label for displaying lookup results, 
and buttons for looking up the customer, confirming the check-in, and canceling the process.
The confirm button is initially hidden and only becomes visible if a valid customer is found during the lookup process. 
The components are arranged in a VBox with appropriate spacing and padding to create a clear and user-friendly interface for the cashier to check in customers for rewards.-->
<VBox alignment="CENTER" spacing="15.0" prefHeight="250.0" prefWidth="350.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="team44.project2.controller.cashier.CustomerCheckInController">
    <children>
        <Label fx:id="titleLabel" text="Customer Rewards Check In"/>
        <TextField fx:id="phoneField" promptText="Phone number" maxWidth="200.0"/>
        <Label fx:id="statusLabel"/>
        <Button fx:id="lookupButton" mnemonicParsing="false" onAction="#handleLookup" text="Look Up"/>
        <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#handleConfirm" text="Confirm" visible="false"/>
        <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" text="Cancel"/>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</VBox>
