<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the payment screen in the cashier payment process, defining the user interface components and their arrangement.
This layout includes a top section that displays the total amount due and instructions for selecting a payment method, 
a center section with a VBox for dynamically displaying payment options based on the selected method, 
and a bottom section with a cancel button to return to the previous screen.-->
<BorderPane prefHeight="450.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="team44.project2.controller.cashier.payment.PaymentScreenController">
    <top>
        <VBox alignment="CENTER" spacing="5.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="totalLabel" text="\$0.00" styleClass="total-display"/>
                <Label fx:id="instructionLabel" text="Select Payment Method"/>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="20.0"/>
            </padding>
        </VBox>
    </top>
    <center>
        <VBox fx:id="contentPane" alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
        </VBox>
    </center>
    <bottom>
        <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel"
                text="Cancel" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
            </BorderPane.margin>
        </Button>
    </bottom>
</BorderPane>