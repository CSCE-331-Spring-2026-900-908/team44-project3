<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<!--FXML layout for the manager dashboard screen, defining the user interface components and their arrangement.
This layout includes a title label and buttons for navigating to different sections of the manager interface, 
such as managing employees, changing menu prices, viewing reports, and managing inventory.
The components are arranged in a Pane with specific layout coordinates to create a clear and 
organized interface for the manager to access various functionalities of the dashboard.-->
<Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="team44.project2.controller.manager.ManagerDashboardController">
   <children>
      <Label layoutX="181.0" layoutY="28.0" text="Manager Dashboard">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <Button fx:id="managerManageEmployeesButton" layoutX="71.0" layoutY="101.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="119.0" text="Manage Employees" />
      <Button fx:id="managerMenuPriceButton" layoutX="300.0" layoutY="101.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="128.0" text="Change Menu Prices" />
      <Button fx:id="managerReportsButton" layoutX="71.0" layoutY="213.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="119.0" text="View Reports" />
      <Button fx:id="managerInventoryButton" layoutX="304.0" layoutY="213.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="142.0" text="Order/Inventory" />
      <Button fx:id="managerDashboardLogoutButton" layoutX="14.0" layoutY="15.0" mnemonicParsing="false" onAction="#handleLogOut" text="Logout" />
   </children>
</Pane>
