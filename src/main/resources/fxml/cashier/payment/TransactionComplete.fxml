<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the transaction complete screen in the cashier payment process, defining the user interface components and their arrangement.
This layout includes labels to display the transaction status (approved), subtotal, tip, and grand total, as well as buttons for printing the receipt, 
emailing the receipt, opting for no receipt, and starting a new sale. 
The components are arranged in a VBox with appropriate spacing and padding to create a clear 
and user-friendly interface for the cashier to finalize the transaction and provide options for receipt handling.-->
<VBox alignment="CENTER" spacing="15.0" prefHeight="350.0" prefWidth="400.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="team44.project2.controller.cashier.payment.TransactionCompleteController">
    <children>
        <Label text="Approved" styleClass="approved-label" />
        <Label fx:id="subtotalLabel" text="Subtotal: $0.00" />
        <Label fx:id="tipLabel" text="Tip: $0.00" />
        <Label fx:id="grandTotalLabel" text="Total: $0.00" />
        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="printReceiptButton" mnemonicParsing="false"
                        onAction="#handlePrintReceipt" text="Print Receipt" />
                <Button fx:id="emailReceiptButton" mnemonicParsing="false"
                        onAction="#handleEmailReceipt" text="Email Receipt" />
                <Button fx:id="noReceiptButton" mnemonicParsing="false"
                        onAction="#handleNoReceipt" text="No Receipt" />
            </children>
        </HBox>
        <Button fx:id="newSaleButton" mnemonicParsing="false" onAction="#handleNewSale"
                text="New Sale" maxWidth="1.7976931348623157E308" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>