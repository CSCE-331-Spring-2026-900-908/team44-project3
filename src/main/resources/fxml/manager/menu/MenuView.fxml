<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<!--FXML layout for the menu item form in the manager menu section, defining the user interface components and their arrangement.
This layout includes text fields for entering menu item details such as name, size, and price, a ComboBox for 
selecting the category, a CheckBox for availability status, and buttons for saving or canceling the form.
The components are arranged in a GridPane for the form fields and an HBox for the action buttons, all contained within 
a VBox to create a structured and user-friendly interface for managing menu items.-->
<StackPane
    fx:controller="team44.project2.controller.manager.menu.MenuViewController"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    prefHeight="500.0"
    prefWidth="700.0">

    <children>
        <VBox spacing="10">
            <children>
                <HBox spacing="10">
                    <children>
                        <Button text="Back" onAction="#handleBack"/>
                    </children>
                </HBox>
                <Label text="Menu Items" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <TableView fx:id="menuTable" prefHeight="400" prefWidth="700">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                        <TableColumn fx:id="sizeColumn" text="Size" prefWidth="100"/>
                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="100"/>
                        <TableColumn fx:id="availableColumn" text="Available" prefWidth="100"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <children>
                        <Button text="Add Item" onAction="#handleAddItem"/>
                        <Button text="Edit Item" onAction="#handleEditItem"/>
                        <Button text="Delete Item" onAction="#handleDeleteItem"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>